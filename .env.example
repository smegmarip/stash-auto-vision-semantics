# Stash URL
STASH_URL=https://your.public.stash.domain.io
STASH_API_KEY=
SEMANTICS_TAG_ID=

# Classifier
CLASSIFIER_MODEL=vision
CLASSIFIER_DEVICE=cuda

# LLM (summary + title)
SEMANTICS_LLM_MODEL=RedHatAI/Llama-3.1-8B-Instruct
SEMANTICS_LLM_DEVICE=cuda

# HuggingFace
SEMANTICS_HF_REPO=smegmarip/tag-classifier
HF_TOKEN=

# Thresholds
SEMANTICS_MIN_CONFIDENCE=0.75
SEMANTICS_JOB_LOCK_TTL=3600

# Redis (embedded in container, localhost for local dev)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=31536000

# Logging
LOG_LEVEL=INFO
